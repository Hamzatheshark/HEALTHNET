generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String         @id @default(cuid())
  email                  String         @unique
  password               String
  firstName              String
  lastName               String
  phone                  String?
  role                   String         @default("PATIENT")
  specialty              String?
  gender                 String?
  address                String?
  birthDate              DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  cin                    String?
  appointmentsAsDoctor   Appointment[]  @relation("DoctorAppointments")
  appointmentsAsPatient  Appointment[]  @relation("PatientAppointments")
  consultationsAsDoctor  Consultation[] @relation("DoctorConsultations")
  consultationsAsPatient Consultation[] @relation("PatientConsultations")
  medicalRecord          MedicalRecord?
  notifications          Notification[]
  managedDoctors    User[]         @relation("SecretaryDoctors")
  managingSecretaries User[]       @relation("SecretaryDoctors")

  @@map("users")
}

model MedicalRecord {
  id              String        @id @default(cuid())
  patientId       String        @unique
  bloodType       String?
  height          String?
  weight          String?
  allergies       String?       @db.Text
  chronicDiseases String?       @db.Text
  medicalHistory  String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  patient         User          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatments      Treatment[]
  vaccinations    Vaccination[]

  @@map("medical_records")
}

model Treatment {
  id              String        @id @default(cuid())
  medicalRecordId String
  name            String
  dosage          String
  frequency       String
  prescribedBy    String
  startDate       DateTime
  endDate         DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId], map: "treatments_medicalRecordId_fkey")
  @@map("treatments")
}

model Vaccination {
  id              String        @id @default(cuid())
  medicalRecordId String
  name            String
  date            DateTime
  nextDue         DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId], map: "vaccinations_medicalRecordId_fkey")
  @@map("vaccinations")
}

model Appointment {
  id           String        @id @default(cuid())
  date         DateTime
  time         String
  type         String        @default("IN_PERSON")
  location     String?
  status       String        @default("PLANIFIE")
  reason       String?
  notes        String?
  patientId    String
  doctorId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  doctor       User          @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)
  patient      User          @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  consultation Consultation?

  @@index([doctorId], map: "appointments_doctorId_fkey")
  @@index([patientId], map: "appointments_patientId_fkey")
  @@map("appointments")
}

model Consultation {
  id              String       @id @default(cuid())
  date            DateTime
  reason          String       @db.Text
  diagnosis       String?      @db.Text
  treatment       String?      @db.Text
  recommendations String?      @db.Text
  notes           String?      @db.Text
  reportUrl       String?
  patientId       String
  doctorId        String
  appointmentId   String?      @unique
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  appointment     Appointment? @relation(fields: [appointmentId], references: [id])
  doctor          User         @relation("DoctorConsultations", fields: [doctorId], references: [id], onDelete: Cascade)
  patient         User         @relation("PatientConsultations", fields: [patientId], references: [id], onDelete: Cascade)

  @@index([doctorId], map: "consultations_doctorId_fkey")
  @@index([patientId], map: "consultations_patientId_fkey")
  @@map("consultations")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   @default("INFO")
  status    String   @default("UNREAD")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "notifications_userId_fkey")
  @@map("notifications")
}

model RolePermission {
  id          String   @id @default(cuid())
  role        String   @unique
  permissions String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("role_permissions")
}
